<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="application.LoginRegisterController">

    <center>

        <HBox alignment="CENTER" spacing="40"
              style="-fx-background-color:#f4f7fb;">

            <!-- Left Side -->
            <VBox alignment="CENTER"
                  spacing="15"
                  prefWidth="300"
                  style="-fx-background-color:#2f5d8c;
                         -fx-padding:30;">

                <Label text="Restaurant System"
                       style="-fx-text-fill:white;
                              -fx-font-size:28;
                              -fx-font-weight:bold;"/>

                <Label text="Login and manage your restaurant easily"
                       wrapText="true"
                       style="-fx-text-fill:white;
                              -fx-font-size:14;"/>

            </VBox>

            <!-- Right Side -->
            <VBox alignment="CENTER"
                  spacing="15"
                  prefWidth="350"
                  style="-fx-background-color:white;
                         -fx-padding:35;">

                <Label text="Login"
                       style="-fx-font-size:24;
                              -fx-font-weight:bold;
                              -fx-text-fill:#2f5d8c;"/>

                <TextField fx:id="usernameField"
                           promptText="Username"
                           prefWidth="250"/>

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               prefWidth="250"/>

                <Button text="Login"
                        prefWidth="250"
                        style="-fx-background-color:#2f5d8c;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;"/>

            </VBox>

        </HBox>

    </center>

</BorderPane>
